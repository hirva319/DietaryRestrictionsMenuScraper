# Google Custom Search API
# Get your API key: https://console.cloud.google.com/apis/credentials
# Set up Custom Search Engine: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_CX=your_custom_search_engine_id_here

# OpenAI API (optional — local keyword classifier works without it)
# Get your API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
